<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>销售线索转化桑基图 - 动态BI看板</title>
    <!-- 使用 Tailwind CSS 进行页面布局 -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- 引入 Plotly.js 用于绘制桑基图 -->
    <script src="https://cdn.plot.ly/plotly-2.27.0.min.js"></script>
    <style>
        body {
            background-color: #f8fafc;
        }
        #chart-container {
            width: 100%;
            height: 650px;
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        }
        /* 自定义复选框颜色 */
        .form-checkbox {
            accent-color: #2563EB;
            width: 1rem;
            height: 1rem;
            cursor: pointer;
        }
    </style>
</head>
<body class="p-4 md:p-8">
    <div class="max-w-7xl mx-auto">
        <header class="mb-6">
            <h1 class="text-3xl font-bold text-gray-800">销售线索转化桑基图 <span class="text-lg font-normal text-white bg-blue-600 px-2 py-1 rounded ml-2">动态分析版</span></h1>
            <p class="text-gray-500 mt-2">支持自定义筛选线索来源，自动计算并展示各渠道真实转化率。</p>
        </header>

        <!-- 控制面板：视图与通道筛选 -->
        <div class="bg-white p-5 rounded-lg border border-gray-200 mb-6 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-bold text-gray-800 flex items-center gap-2">
                    <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
                    业务通道筛选 (入口源)
                </h2>
                <button onclick="selectAll()" class="text-sm font-medium text-blue-600 hover:text-blue-800 bg-blue-50 px-3 py-1 rounded">全选 / 恢复默认</button>
            </div>
            <div class="flex flex-wrap gap-4" id="filter-container">
                <!-- JS 动态生成 -->
            </div>
        </div>

        <!-- 图表容器 -->
        <div id="chart-container" class="p-4"></div>

    </div>

    <script>
        // 1. 定义核心原始数据
        // 这代表业务的客观真实数据，无论用户怎么筛选，"转化率"的基数都不变。
        const rawData = {
            nodes: [
                { id: 0, name: "销售线索", layer: 1, x: 0.01, y: 0.1, color: "#3B82F6" },
                { id: 1, name: "公司线索", layer: 1, x: 0.01, y: 0.5, color: "#60A5FA" },
                { id: 2, name: "再分配线索", layer: 1, x: 0.01, y: 0.9, color: "#93C5FD" },
                { id: 3, name: "无效线索", layer: 2, x: 0.5, y: 0.1, color: "#CBD5E1" },
                { id: 4, name: "线索转客户", layer: 2, x: 0.5, y: 0.4, color: "#2563EB" },
                { id: 5, name: "退回线索", layer: 2, x: 0.5, y: 0.6, color: "#E2E8F0" },
                { id: 6, name: "销售自有客户", layer: 2, x: 0.5, y: 0.9, color: "#0EA5E9" },
                { id: 7, name: "成交合同", layer: 3, x: 0.99, y: 0.3, color: "#1E3A8A" },
                { id: 8, name: "流失客户", layer: 3, x: 0.99, y: 0.7, color: "#F1F5F9" }
            ],
            links: [
                { source: 0, target: 3, value: 6560 }, // 销售线索 -> 无效
                { source: 0, target: 4, value: 1040 }, // 销售线索 -> 转客
                { source: 0, target: 5, value: 400 },  // 销售线索 -> 退回
                { source: 1, target: 3, value: 8500 }, // 公司线索 -> 无效
                { source: 1, target: 4, value: 1000 }, // 公司线索 -> 转客
                { source: 1, target: 5, value: 500 },  // 公司线索 -> 退回
                { source: 2, target: 3, value: 1560 }, // 再分配 -> 无效
                { source: 2, target: 4, value: 300 },  // 再分配 -> 转客
                { source: 2, target: 5, value: 140 },  // 再分配 -> 退回
                { source: 4, target: 7, value: 351 },  // 转客户 -> 成交
                { source: 4, target: 8, value: 1989 }, // 转客户 -> 流失
                { source: 6, target: 7, value: 216 },  // 自有客户 -> 成交
                { source: 6, target: 8, value: 984 }   // 自有客户 -> 流失
            ]
        };

        // 2. 预计算原始转化率（基于未筛选的全量数据）
        const rawOutTotals = {};
        const rawConvRates = {}; // 存储转化率百分比文本
        rawData.links.forEach(l => {
            rawOutTotals[l.source] = (rawOutTotals[l.source] || 0) + l.value;
        });
        rawData.links.forEach(l => {
            // L1 的成功目标是 4(转客户)；L2 的成功目标是 7(成交合同)
            if (l.target === 4 || l.target === 7) {
                rawConvRates[l.source] = ((l.value / rawOutTotals[l.source]) * 100).toFixed(1) + '%';
            }
        });

        // 3. 初始化 UI 过滤器 (仅生成第一层和销售自有客户的选项)
        function initFilters() {
            const container = document.getElementById('filter-container');
            // 仅允许筛选这四个入口来源节点
            const filterableIds = [0, 1, 2, 6]; 
            
            rawData.nodes.filter(n => filterableIds.includes(n.id)).forEach(node => {
                const html = `
                    <label class="flex items-center gap-2 cursor-pointer hover:bg-gray-50 p-2 pr-4 rounded border border-gray-100 bg-gray-50/50">
                        <input type="checkbox" checked value="${node.id}" class="form-checkbox node-filter" onchange="renderSankey()">
                        <span class="flex items-center gap-2 text-sm font-medium text-gray-700">
                            ${node.name}
                        </span>
                    </label>
                `;
                container.insertAdjacentHTML('beforeend', html);
            });
        }

        // 4. 颜色透明度转换函数 (生成流线颜色)
        function hexToRgba(hex, alpha) {
            let r = parseInt(hex.slice(1, 3), 16),
                g = parseInt(hex.slice(3, 5), 16),
                b = parseInt(hex.slice(5, 7), 16);
            return `rgba(${r}, ${g}, ${b}, ${alpha})`;
        }

        // 5. 核心渲染函数：根据复选框状态动态构建 Plotly 数据
        function renderSankey() {
            // 获取当前选中的来源节点 ID
            const checkboxes = document.querySelectorAll('.node-filter');
            // 其他非入口节点 (中间状态和最终结果) 默认始终保留在激活集合中
            const activeIds = new Set([3, 4, 5, 7, 8]); 
            
            checkboxes.forEach(cb => { 
                if (cb.checked) activeIds.add(parseInt(cb.value)); 
            });

            // 过滤出激活的连线 (连线的两端都必须是激活的节点)
            const activeLinks = rawData.links.filter(l => activeIds.has(l.source) && activeIds.has(l.target));

            // 计算当前视图下每个节点的流入/流出量
            const viewOutTotals = {};
            const viewInTotals = {};
            activeLinks.forEach(l => {
                viewOutTotals[l.source] = (viewOutTotals[l.source] || 0) + l.value;
                viewInTotals[l.target] = (viewInTotals[l.target] || 0) + l.value;
            });

            // 过滤节点：只保留被选中的入口节点，以及有实际流量连接的中间/结果节点
            const activeNodes = rawData.nodes.filter(n => {
                // 如果是可筛选的入口节点，检查它是否被勾选
                if ([0, 1, 2, 6].includes(n.id)) return activeIds.has(n.id);
                // 对于其他固定节点，只要有流量流入或流出，就将其显示出来
                return (viewInTotals[n.id] || 0) > 0 || (viewOutTotals[n.id] || 0) > 0;
            });

            // Plotly 的 sources 和 targets 需要基于当前过滤后数组的索引 (0, 1, 2...)
            const idToIndex = {};
            activeNodes.forEach((n, index) => { idToIndex[n.id] = index; });

            // 构建最终送入 Plotly 的数据数组
            const pLabels = [];
            const pColors = [];
            const pX = [];
            const pY = [];

            // 生成动态 Label
            activeNodes.forEach(n => {
                let currentVol = Math.max(viewOutTotals[n.id] || 0, viewInTotals[n.id] || 0);
                
                // 拼接文本: 名称 + 当前视图量
                let labelText = `<b>${n.name}</b><br><span style='font-size:11px;color:#475569'>视图量: ${currentVol.toLocaleString()}</span>`;
                
                // 附加该渠道的客观转化率 (不受隐藏其他节点影响)
                if (rawConvRates[n.id]) {
                    let rateName = n.layer === 1 ? '转客率' : '成交率';
                    let rateColor = n.layer === 1 ? '#2563EB' : '#1E3A8A';
                    labelText += `<br><span style='font-size:12px; font-weight:bold; color:${rateColor}'>${rateName}: ${rawConvRates[n.id]}</span>`;
                }

                pLabels.push(labelText);
                pColors.push(n.color);
                pX.push(n.x);
                pY.push(n.y);
            });

            // 构建链接数据
            const pSources = [];
            const pTargets = [];
            const pValues = [];
            const pLinkColors = [];
            const pCustomData = []; // 用于 hover 时显示自定义数据

            activeLinks.forEach(l => {
                pSources.push(idToIndex[l.source]);
                pTargets.push(idToIndex[l.target]);
                pValues.push(l.value);
                
                // 计算当前这条线占源节点“原始总量”的比例
                let percentage = ((l.value / rawOutTotals[l.source]) * 100).toFixed(1);
                pCustomData.push(percentage);

                // 判断颜色: 流向无效/退回/流失的设为灰色，否则继承源节点颜色的半透明
                if (l.target === 3 || l.target === 5 || l.target === 8) {
                    pLinkColors.push("rgba(203, 213, 225, 0.4)"); 
                } else {
                    let sourceColor = rawData.nodes.find(n => n.id === l.source).color;
                    pLinkColors.push(hexToRgba(sourceColor, 0.45));
                }
            });

            // 绘制图表
            const data = [{
                type: "sankey",
                orientation: "h",
                node: {
                    pad: 25,
                    thickness: 35,
                    line: { width: 0 },
                    label: pLabels,
                    x: pX,
                    y: pY,
                    color: pColors
                },
                link: {
                    source: pSources,
                    target: pTargets,
                    value: pValues,
                    color: pLinkColors,
                    customdata: pCustomData, // 传入百分比
                    hovertemplate: "%{source.label} -> %{target.label}<br>流量: <b>%{value}</b><br>流失/转化占比: <b>%{customdata}%</b><extra></extra>"
                }
            }];

            const layout = {
                font: { size: 13, family: "PingFang SC, Microsoft YaHei, sans-serif" },
                margin: { l: 20, r: 20, t: 20, b: 20 },
                plot_bgcolor: 'rgba(0,0,0,0)',
                paper_bgcolor: 'rgba(0,0,0,0)',
                hoverlabel: { font: { family: "PingFang SC" } }
            };

            const config = {
                responsive: true,
                displayModeBar: false
            };

            Plotly.react('chart-container', data, layout, config);
        }

        // 全选功能
        function selectAll() {
            document.querySelectorAll('.node-filter').forEach(cb => cb.checked = true);
            renderSankey();
        }

        // 初始化执行
        window.onload = () => {
            initFilters();
            renderSankey();
        };

        // 窗口调整
        window.onresize = function() {
            Plotly.Plots.resize('chart-container');
        };
    </script>
</body>
</html>