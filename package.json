{
  "name": "crm-unified",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:business": "vitest run src/lib/crmAdapters.test.js backend/src/crm/crm-state.service.test.ts",
    "dev:api": "npm --prefix backend run start:dev",
    "build:api": "npm --prefix backend run build",
    "start:api": "npm --prefix backend run start",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:api\"",
    "deploy": "vite build && git add -A && git commit -m \"build: $(date '+%Y-%m-%d %H:%M:%S')\" && git push origin main",
    "watch": "node scripts/auto-push.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.6.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.1",
    "socket.io-client": "^4.8.1",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "vite": "^4.4.0",
    "vitest": "^4.1.5"
  }
}
